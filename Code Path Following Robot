/**
 * Two-Sensor Line Follower Robot
 * * Behavior:
 * - Moves forward on White (Low, Low)
 * - Corrects left when Right hits Black (High, Low)
 * - Corrects right when Left hits Black (Low, High)
 * - Stops completely when both hit Black (High, High)
 */

// --- Pin Definitions ---
// IR Sensors
const int IR_SENSOR_RIGHT = 13;
const int IR_SENSOR_LEFT  = 12;

// Right Motor (L298N / L293D Motor Driver)
const int enableRightMotor = 10; // PWM Speed Control
const int rightMotorPin1   = 4;  // Direction Control 1
const int rightMotorPin2   = 5;  // Direction Control 2

// Left Motor (L298N / L293D Motor Driver)
const int enableLeftMotor  = 11; // PWM Speed Control
const int leftMotorPin1    = 6;  // Direction Control 1
const int leftMotorPin2    = 7;  // Direction Control 2

// --- Speed Configuration ---
// PWM Range: 0 (Off) to 255 (Full Speed). 45 is a steady, gentle pace.
const int MOTOR_SPEED = 60;

void setup() 
{
  // Initialize Motor Driver Control Pins as Outputs
  pinMode(enableRightMotor, OUTPUT);
  pinMode(rightMotorPin1, OUTPUT);
  pinMode(rightMotorPin2, OUTPUT);

  pinMode(enableLeftMotor, OUTPUT);
  pinMode(leftMotorPin1, OUTPUT);
  pinMode(leftMotorPin2, OUTPUT);

  // Initialize IR Sensor Pins as Inputs
  pinMode(IR_SENSOR_RIGHT, INPUT);
  pinMode(IR_SENSOR_LEFT, INPUT);

  // Ensure motors are completely stopped at startup
  setMotors(0, 0);
}

void loop() 
{
  // Read current sensor states
  int rightSensor = digitalRead(IR_SENSOR_RIGHT);
  int leftSensor  = digitalRead(IR_SENSOR_LEFT);

  // State 1: Both sensors on Black Surface -> STOP
  if (rightSensor == HIGH && leftSensor == HIGH) 
  {
    setMotors(0, 0);
  }
  // State 2: Both sensors on White Surface -> MOVE FORWARD
  else if (rightSensor == LOW && leftSensor == LOW) 
  {
    setMotors(MOTOR_SPEED, MOTOR_SPEED);
  }
  // State 3: Right sensor deviates onto Black -> STEER LEFT
  else if (rightSensor == HIGH && leftSensor == LOW) 
  {
    setMotors(0, MOTOR_SPEED);
  }
  // State 4: Left sensor deviates onto Black -> STEER RIGHT
  else if (rightSensor == LOW && leftSensor == HIGH) 
  {
    setMotors(MOTOR_SPEED, 0);
  }
}

/**
 * Helper function to drive the H-Bridge motor controller.
 * Accepts values from -255 to 255.
 */
void setMotors(int rightSpeed, int leftSpeed) 
{
  // --- Right Motor Direction Logic ---
  if (rightSpeed > 0) 
  {
    digitalWrite(rightMotorPin1, HIGH);
    digitalWrite(rightMotorPin2, LOW);
  } 
  else if (rightSpeed < 0) 
  {
    digitalWrite(rightMotorPin1, LOW);
    digitalWrite(rightMotorPin2, HIGH);
  } 
  else 
  {
    digitalWrite(rightMotorPin1, LOW);
    digitalWrite(rightMotorPin2, LOW);
  }

  // --- Left Motor Direction Logic ---
  if (leftSpeed > 0) 
  {
    digitalWrite(leftMotorPin1, HIGH);
    digitalWrite(leftMotorPin2, LOW);
  } 
  else if (leftSpeed < 0) 
  {
    digitalWrite(leftMotorPin1, LOW);
    digitalWrite(leftMotorPin2, HIGH);
  } 
  else 
  {
    digitalWrite(leftMotorPin1, LOW);
    digitalWrite(leftMotorPin2, LOW);
  }

  // --- Speed Control via PWM ---
  analogWrite(enableRightMotor, abs(rightSpeed));
  analogWrite(enableLeftMotor, abs(leftSpeed));
} 
